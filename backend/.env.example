# ────────────────────────────────────────────────────
# Multimodal Disruption Monitor - Environment Variables
# ────────────────────────────────────────────────────

# Database (optional - system works in API-only mode without DB)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/multimodal_disruptions

# HERE Traffic API (free tier: 250k requests/month)
# Sign up at: https://developer.here.com/
HERE_API_KEY=

# News API (free tier: 100 requests/day)
# Sign up at: https://newsapi.org/
NEWS_API_KEY=

# Reddit API (free)
# Create app at: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=multimodal-disruption-monitor/1.0

# NLP Model (default uses DistilBERT, works on CPU)
NLP_MODEL=distilbert-base-uncased-finetuned-sst-2-english

# Data collection intervals (seconds)
TRAFFIC_INTERVAL=300
SOCIAL_INTERVAL=600
NEWS_INTERVAL=900

# Disruption detection thresholds
CONGESTION_THRESHOLD=0.6
DISRUPTION_CONFIDENCE_MIN=0.5
